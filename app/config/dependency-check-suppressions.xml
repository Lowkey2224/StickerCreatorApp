    <!-- Android specific suppressions for common false positives -->
    <suppress>
        <notes><![CDATA[
        Android support libraries - these are managed by Google and updated through SDK
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/androidx\..*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
    
    <suppress>
        <notes><![CDATA[
        Kotlin standard library - managed by JetBrains
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.jetbrains\.kotlin/.*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
    
</suppressions>
